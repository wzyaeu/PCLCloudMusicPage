<local:MyCard Margin="4"
              Width="163">
    <StackPanel Margin="10">
        <local:MyImage
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            Source="{img}"/>
        <StackPanel Orientation="Horizontal">
            {tag}
            <TextBlock Margin="0,5,0,0"
                       FontSize="17"
                       FontWeight="Bold"
                       Text="{name}"
                       ToolTip="{name}"/>
        </StackPanel>
        <TextBlock Margin="0,2,0,0"
                   FontSize="12"
                   Text="{artists}"
                   Height="14"
                   ToolTip="{artists}"/>
        <StackPanel Orientation="Horizontal"
                    Margin="0,2,0,0">
            <local:MyButton
                Margin="1,0,1,0"
                Height="18"
                Width="50"
                Text="查看"
                EventType="打开网页"
                EventData="{url}"/>
            <TextBlock Margin="1,0"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Text="{album}"
                       ToolTip="{album}"/>
        </StackPanel>
    </StackPanel>
</local:MyCard>