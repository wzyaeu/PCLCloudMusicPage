<StackPanel>

    <local:MyCard Margin="0,0,0,3">
        <StackPanel Margin="5"
                    Orientation="Horizontal">
            <Border Background="{DynamicResource ColorBrush4}"
                    CornerRadius="5">
                <TextBlock Margin="5,0,5,0"
                           VerticalAlignment="Center"
                           FontSize="18"
                           Foreground="{DynamicResource ColorBrush7}"
                           Text="Music 云音乐热门"/>
            </Border>
            <TextBlock Margin="10,3,3,3"
                       FontWeight="Bold"
                       FontSize="16"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource ColorBrush3}"
                       Text="投票排行榜"/>
            <local:MyIconTextButton Margin="2"
                                    Height="35"
                                    VerticalAlignment="Center"
                                    Text="刷新"
                                    EventType="刷新页面"
                                    LogoScale="1"
                                    Logo="M841.140212 512.013257c0 181.498884-147.641328 329.140212-329.140212 329.140212s-329.140212-147.641328-329.140212-329.140212c0-175.391505 137.999348-318.746696 311.068586-328.211305l0 99.641714c0 3.249345 1.749929 6.286578 4.571392 7.928622 1.428103 0.821022 3.000662 1.214162 4.571392 1.214162s3.143289-0.39314 4.571392-1.214162l237.569748-137.141755c2.821463-1.642044 4.571392-4.679277 4.571392-7.928622s-1.749929-6.286578-4.571392-7.928622l-237.569748-137.141755c-2.856206-1.642044-6.286578-1.642044-9.142784 0-2.821463 1.642044-4.571392 4.679277-4.571392 7.928622l0 101.499527C280.537631 120.195606 109.717518 296.300248 109.717518 512.013257c0 221.820389 180.462093 402.282482 402.282482 402.282482s402.282482-180.462093 402.282482-402.282482L841.140212 512.013257z"/>
        </StackPanel>
    </local:MyCard>
    <local:MyCard Margin="0,5">
        <StackPanel Margin="0,10">
            <local:MyListItem Margin="10,2"
                              Logo="pack://application:,,,/images/Blocks/RedstoneBlock.png"
                              Title="投稿音乐"
                              Info="提交一首你喜欢的音乐参与投票"
                              EventType="打开网页"
                              Type="Clickable"
                              EventData="https://github.com/wzyaeu/PCLCloudMusicPage/issues/new?template=music_vote.yml"/>
            <local:MyListItem Margin="10,2"
                              Logo="pack://application:,,,/images/Blocks/Fabric.png"
                              Title="参与投票"
                              Info="在此处参与歌曲投票"
                              EventType="打开网页"
                              Type="Clickable"
                              EventData="https://github.com/wzyaeu/PCLCloudMusicPage/discussions/categories/musicvote?discussions_q=is%3Aopen+category%3AMusicVote+label%3A%E9%9F%B3%E4%B9%90%E6%8A%95%E7%A5%A8-%E8%BF%9B%E8%A1%8C%E4%B8%AD+"/>
        </StackPanel>
    </local:MyCard>
    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <TextBlock FontSize="17"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource ColorBrush3}"
                   Text="投票排行榜"/>
        <Line X1="0"
              Grid.Column="1"
              Y1="0"
              X2="1000"
              Y2="0"
              StrokeThickness="2"
              VerticalAlignment="Center"
              Stroke="{DynamicResource ColorBrush3}"
              Margin="10,0"/>
    </Grid>
    <WrapPanel VerticalAlignment="Center"
               Margin="0,2">
        {music}
    </WrapPanel>
</StackPanel>
