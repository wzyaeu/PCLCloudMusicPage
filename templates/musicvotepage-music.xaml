<local:MyCard Margin="4"
              Width="163">
    <StackPanel Margin="10">
        <Grid Height="143"
              Width="143">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <local:MyImage
                    Source="{img}"/>
            </StackPanel>
        </Grid>
        <StackPanel Orientation="Horizontal">
            <Border VerticalAlignment="Center"
                    Height="20"
                    Width="45"
                    Margin="0,5,5,-1"
                    Background="{color}"
                    CornerRadius="7">
                <StackPanel HorizontalAlignment="Center"
                            Margin="3"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <TextBlock FontSize="10"
                               Foreground="{DynamicResource ColorBrush8}"
                               VerticalAlignment="Bottom"
                               Text="No."/>
                    <TextBlock FontSize="15"
                               Margin="0,0,0,-2"
                               Foreground="{DynamicResource ColorBrush8}"
                               VerticalAlignment="Bottom"
                               Text="{rank}"/>
                </StackPanel>
            </Border>
            <TextBlock Margin="0,5,0,0"
                       FontSize="17"
                       FontWeight="Bold"
                       Text="{name}"
                       ToolTip="{name}"/>
        </StackPanel>
        <TextBlock Margin="0,2,0,0"
                   FontSize="12"
                   Text="{artists}"
                   Height="14"
                   ToolTip="{artists}"/>
        <StackPanel Orientation="Horizontal"
                    Margin="0,2,0,0">
            <local:MyButton
                Margin="1,0,1,0"
                Height="18"
                Width="37"
                Text="查看"
                EventType="打开网页"
                EventData="{url}"/>
            <local:MyButton
                Visibility="{khd}"
                Margin="1,0,1,0"
                Height="18"
                Width="50"
                ToolTip="呼出本地网易云音乐打开！"
                Text="客户端"
                EventType="打开网页"
                EventData="https://p.kaphia.qzz.io/PCLCloudMusicPageRedirect?id={id}&amp;type={khdtype}"/>
            <TextBlock Margin="1,0"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Text="{album}"
                       ToolTip="{album}"/>
        </StackPanel>
    </StackPanel>

    <Border VerticalAlignment="Top"
            Height="25"
            HorizontalAlignment="Left"
            Margin="-5,-7,-5,0"
            Background="#2ac2d1"
            CornerRadius="7">
        <StackPanel HorizontalAlignment="Center"
                    Margin="10,3,10,3"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
            <TextBlock FontSize="18"
                       Margin="0,0,2,-1"
                       Foreground="{DynamicResource ColorBrush8}"
                       VerticalAlignment="Bottom"
                       Text="{vote}"/>
            <TextBlock FontSize="12"
                       Margin="0,0,0,1"
                       Foreground="{DynamicResource ColorBrush8}"
                       VerticalAlignment="Bottom"
                       Text="票"/>
            <local:MyButton
                Margin="5,0,-5,0"
                Width="65"
                Text="参与投票"
                EventType="打开网页"
                EventData="{voteurl}"/>

        </StackPanel>
    </Border>
</local:MyCard>