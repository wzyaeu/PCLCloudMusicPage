<Border Height="25"
        Margin="1"
        Background="#2ac2d1"
        CornerRadius="7"
        HorizontalAlignment="Left"
        ToolTip="此歌曲已累计 {count} 票">
    <StackPanel HorizontalAlignment="Center"
                Margin="10,3,10,3"
                VerticalAlignment="Center"
                Orientation="Horizontal">
        <TextBlock FontSize="18"
                   Margin="0,0,2,-1"
                   Foreground="{DynamicResource ColorBrush8}"
                   VerticalAlignment="Bottom"
                   Text="{count}"/>
        <TextBlock FontSize="12"
                   Margin="0,0,0,1"
                   Foreground="{DynamicResource ColorBrush8}"
                   VerticalAlignment="Bottom"
                   Text="票"/>
        <local:MyButton
            Margin="5,0,-5,0"
            Width="45"
            Text="投票"
            EventType="打开网页"
            EventData="{voteurl}"/>
    </StackPanel>
</Border>