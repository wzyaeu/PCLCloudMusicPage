        </StackPanel>
    </local:MyCard>
    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <TextBlock FontSize="17"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Foreground="{DynamicResource ColorBrush3}"
                   Text="新歌速递"/>
        <local:MyIconTextButton
            Grid.Column="1"
            Height="35"
            VerticalAlignment="Center"
            Text="查看全部"
            EventType="打开帮助"
            EventData="https://cloudmusic.p.kaphia.qzz.io/newsong.json"
            LogoScale="1"
            Logo="M633.361447 510.516239 253.723194 890.25682 320.748276 957.179574 767.411612 510.516239 320.748276 63.852903 253.723194 130.775657Z"/>
        <Line X1="0"
              Grid.Column="2"
              Y1="0"
              X2="1000"
              Y2="0"
              StrokeThickness="2"
              VerticalAlignment="Center"
              Stroke="{DynamicResource ColorBrush3}"
              Margin="10,0"/>
    </Grid>
    <WrapPanel VerticalAlignment="Center"
               Margin="0,2">
        {music}
    </WrapPanel>
    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <TextBlock FontSize="17"
                   FontWeight="Bold"
                   Foreground="{DynamicResource ColorBrush3}"
                   Text="更多页面"/>
        <Line X1="0"
              Grid.Column="1"
              Y1="0"
              X2="1000"
              Y2="0"
              StrokeThickness="2"
              VerticalAlignment="Center"
              Stroke="{DynamicResource ColorBrush3}"
              Margin="10,0"/>
    </Grid>
    <local:MyCard Margin="0,5">
        <StackPanel Margin="0,10">
            <local:MyListItem Margin="10,2"
                              Logo="pack://application:,,,/images/Blocks/Anvil.png"
                              Title="热门榜单"
                              Info="飙升榜、新歌榜等官方榜单"
                              EventType="打开帮助"
                              Type="Clickable"
                              EventData="https://cloudmusic.p.kaphia.qzz.io/rank_list.json"/>
            <local:MyListItem Margin="10,2"
                              Logo="pack://application:,,,/images/Blocks/GoldBlock.png"
                              Title="精品歌单"
                              Info="热门精品歌单推荐"
                              EventType="打开帮助"
                              Type="Clickable"
                              EventData="https://cloudmusic.p.kaphia.qzz.io/highqualitylist.json"/>
            <local:MyListItem Margin="10,2"
                              Logo="pack://application:,,,/images/Blocks/RedstoneBlock.png"
                              Title="新碟上架"
                              Info="最新热门数字专辑"
                              EventType="打开帮助"
                              Type="Clickable"
                              EventData="https://cloudmusic.p.kaphia.qzz.io/newsong.json"/>
        </StackPanel>
    </local:MyCard>
    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <TextBlock FontSize="17"
                   FontWeight="Bold"
                   Foreground="{DynamicResource ColorBrush3}"
                   Text="关于主页"/>
        <Line X1="0"
              Grid.Column="1"
              Y1="0"
              X2="1000"
              Y2="0"
              StrokeThickness="2"
              VerticalAlignment="Center"
              Stroke="{DynamicResource ColorBrush3}"
              Margin="10,0"/>
    </Grid>
    <local:MyCard Margin="0,5">
        <StackPanel>
            <Border Background="{DynamicResource ColorBrush4}"
                    CornerRadius="5,5,0,0"
                    Height="100">
                <StackPanel Margin="16"
                            HorizontalAlignment="Center">
                    <TextBlock FontSize="32"
                               Foreground="{DynamicResource ColorBrush7}"
                               Text="Music 云音乐热门"
                               HorizontalAlignment="Center"/>
