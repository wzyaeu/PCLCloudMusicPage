            </StackPanel>
        </StackPanel>
    </local:MyCard>
    <local:MyCard Margin="0,5"
                  Title="特别鸣谢">
        <StackPanel Margin="15,40,15,15">
            <local:MyListItem
                Margin="2"
                Title="网易云音乐"
                Info="提供了歌曲信息及图片！"
                EventType="打开网页"
                EventData="https://bilibili.com"
                Type="Clickable"/>
            <local:MyListItem
                Margin="2"
                Title="MusicLibrary"
                Info="本项目的基础API库，提供了获取歌曲信息的渠道！"
                EventType="打开网页"
                EventData="https://pypi.org/project/pymusiclibrary"
                Type="Clickable"/>
            <local:MyListItem
                Margin="2"
                Title="Wzyaeu / Kaphia"
                Info="主页制作团"
                ToolTip="我们两个只是⌈分身⌋，仅此而已"
